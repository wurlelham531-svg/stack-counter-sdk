{
  "name": "stack-counter-sdk",
  "version": "0.1.14",
  "description": "TypeScript SDK for collaborative on-chain counters on the Stacks blockchain — increment, snapshot, audit history.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:utils": "vitest run tests/utils.test.ts",
    "test:contract": "vitest run tests/contract.test.ts",
    "test:constants": "vitest run tests/constants.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stacks",
    "clarity",
    "blockchain",
    "sdk",
    "counter",
    "increment",
    "collaboration",
    "analytics",
    "web3"
  ],
  "author": "Stack-Counter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wurlelham531-svg/stack-counter-sdk"
  },
  "dependencies": {
    "@stacks/transactions": "^6.12.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
